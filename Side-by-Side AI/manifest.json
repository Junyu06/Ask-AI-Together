{
  "manifest_version": 3,
  "name": "Side-by-Side AI",
  "description": "Multi-AI prompt broadcast with multi-window tiling and local session history.",
  "version": "0.3.0",
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "tabs",
    "windows"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://chat.deepseek.com/*",
    "https://www.kimi.com/*",
    "https://chat.qwen.ai/*",
    "https://www.doubao.com/*",
    "https://yuanbao.tencent.com/*",
    "https://grok.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "icons": {
    "128": "store-assets/icon-128.png"
  },
  "action": {
    "default_title": "Side-by-Side AI — 侧栏 / 平铺",
    "default_icon": "store-assets/icon-128.png"
  },
  "options_ui": {
    "page": "ui/options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "legacy/content.js"
      ],
      "all_frames": true,
      "run_at": "document_idle",
      "match_about_blank": true
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content-sites.js",
        "content/content-dom.js",
        "content/content-response.js",
        "content/content-input.js",
        "content/content-attachments.js",
        "content/content-send-runtime.js",
        "content/content-quote-ui.js"
      ],
      "all_frames": true,
      "run_at": "document_idle",
      "match_about_blank": true
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://chat.deepseek.com/*",
        "https://www.kimi.com/*",
        "https://kimi.com/*",
        "https://chat.qwen.ai/*",
        "https://www.doubao.com/*",
        "https://doubao.com/*",
        "https://yuanbao.tencent.com/*",
        "https://grok.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*"
      ],
      "js": [
        "embed/page-embed-options.js"
      ],
      "all_frames": false,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "ui/options/options.html",
        "ui/options/options.js",
        "ui/options/options.css",
        "assets/styles.css",
        "assets/quick-focus.js",
        "assets/options-i18n.js",
        "assets/options-settings.js",
        "ui/controller/controller.css",
        "legacy/index.html",
        "legacy/app.js",
        "legacy/styles.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
